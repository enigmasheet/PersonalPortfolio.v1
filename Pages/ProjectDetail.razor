@page "/projects/{Slug}"

<SeoMeta Title="@(_project?.Title ?? "Project")"
         Description="@(_project?.Description ?? "View project details.")"
         OgType="article"
         OgUrl="@($"{SiteConfig.BaseUrl}/projects/{Slug}")" />

<MudContainer Class="page-section" MaxWidth="MaxWidth.Small">
    @if (_loading)
    {
        <Skeleton Type="card" Count="1" />
    }
    else if (_project == null)
    {
        <div class="text-center py-8">
            <MudText Typo="Typo.h2" Color="Color.Primary" Class="mb-4">Not found</MudText>
            <MudText Typo="Typo.body1" Class="text-secondary mb-6">The project you're looking for doesn't exist.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/projects">Back to Projects</MudButton>
        </div>
    }
    else
    {
        <div class="d-flex align-center gap-2 mb-4 flex-wrap">
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/projects" StartIcon="@Icons.Material.Filled.ArrowBack">Back</MudButton>
        </div>

        <MudCard Outlined="true" Class="mb-6">
            @{
                var imageUrl = _project.ImageUrls?.FirstOrDefault();
                if (!string.IsNullOrWhiteSpace(imageUrl))
                {
                    <img src="@imageUrl" alt="@_project.Title" style="width:100%;height:400px;object-fit:cover;border-radius:8px 8px 0 0;" />
                }
            }
            <MudCardContent>
                <MudText Typo="Typo.h3">@_project.Title</MudText>
                <MudText Typo="Typo.body1" Class="text-secondary mt-2 mb-4" Style="line-height:1.7;">@_project.Description</MudText>

                @if (_project.Technologies is { Count: > 0 })
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Technologies</MudText>
                    <div class="d-flex flex-wrap gap-1 mb-4">
                        @foreach (var tech in _project.Technologies)
                        {
                            <MudChip @key="tech" T="string" Size="Size.Small" Color="Color.Primary">@tech</MudChip>
                        }
                    </div>
                }

                @if (_project.Tags is { Count: > 0 })
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Tags</MudText>
                    <div class="d-flex flex-wrap gap-1 mb-4">
                        @foreach (var tag in _project.Tags)
                        {
                            <MudChip @key="tag" T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@tag</MudChip>
                        }
                    </div>
                }

                <div class="d-flex flex-wrap gap-2 mt-4">
                    @if (!string.IsNullOrWhiteSpace(_project.GitHubLink))
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@_project.GitHubLink" Target="_blank" StartIcon="@Icons.Custom.Brands.GitHub">View Source</MudButton>
                    }
                    @if (!string.IsNullOrWhiteSpace(_project.LiveDemo))
                    {
                        if (_project.LiveDemoActive)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@_project.LiveDemo" Target="_blank">Live Demo</MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" Disabled="true">Offline</MudButton>
                        }
                    }
                </div>
            </MudCardContent>
        </MudCard>
    }
</MudContainer>

