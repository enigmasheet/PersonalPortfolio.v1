@page "/contact"

<SeoMeta Title="@Seo.PageTitle("Contact")"
         Description="@(_content?.Sections?["contact"]?.Description ?? "Get in touch with Abhay Kumar Mandal.")" />

<div data-reveal><MudContainer Class="page-section" MaxWidth="MaxWidth.Small">
    <SectionHeader Label="@_content?.Sections?["contact"]?.Label"
                   Title="@_content?.Sections?["contact"]?.Title"
                   Description="@_content?.Sections?["contact"]?.Description" />

    <MudPaper Class="pa-6" Elevation="0" Outlined="true">
        <MudText Typo="Typo.body1" Align="Align.Center" Class="text-secondary mb-6">
            @(_content?.Contact?.Intro ?? "I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision. Feel free to reach out!")
        </MudText>

        @if (_submitted)
        {
            <div class="text-center py-6">
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    Thanks, @_form.Name! Your message has been sent. I'll get back to you soon.
                </MudAlert>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ResetForm">Send another message</MudButton>
            </div>
        }
        else
        {
            <MudForm @ref="_formRef" @bind-IsValid="_formValid">
                <div class="visually-hidden" aria-hidden="true">
                    <input type="text" @bind="_honeypot" tabindex="-1" autocomplete="off"
                           style="position:absolute;width:1px;height:1px;padding:0;overflow:hidden;clip:rect(0,0,0,0);border:0;" />
                </div>

                <div class="d-flex flex-column gap-4 mb-4">
                    <MudTextField @bind-Value="_form.Name" Label="Name" Placeholder="Your name"
                                  Variant="Variant.Outlined" For="@(() => _form.Name)"
                                  Required="true" RequiredError="Name is required" />
                    <MudTextField @bind-Value="_form.Email" Label="Email" Placeholder="your@email.com"
                                  Variant="Variant.Outlined" For="@(() => _form.Email)"
                                  Required="true" RequiredError="Email is required" />
                    <MudTextField @bind-Value="_form.Message" Label="Message" Placeholder="Your message..."
                                  Variant="Variant.Outlined" For="@(() => _form.Message)"
                                  Required="true" RequiredError="Message is required"
                                  Lines="5" MaxLength="5000" />
                </div>

                <div class="d-flex justify-center mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_submitting || !_formValid)"
                               OnClick="HandleSubmit" Class="px-8">
                        @if (_submitting)
                        {
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="me-2" />
                            <span>Sending...</span>
                        }
                        else
                        {
                            <span>Send Message</span>
                        }
                    </MudButton>
                </div>
            </MudForm>

            <div class="d-flex align-center my-6 gap-4">
                <MudDivider Class="flex-grow-1" />
                <MudText Typo="Typo.body2" Class="text-secondary">or</MudText>
                <MudDivider Class="flex-grow-1" />
            </div>

            <div class="text-center">
                <MudText Typo="Typo.body1" Class="text-secondary">
                    Email me directly at <MudLink Href="@($"mailto:{SiteConfig.Email}")">@SiteConfig.Email</MudLink>
                </MudText>
            </div>
        }
    </MudPaper>
    </MudContainer></div>

